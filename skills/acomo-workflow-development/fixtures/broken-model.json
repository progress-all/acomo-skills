      { "id": "2", "type": "task", "name": "申請" },
      { "id": "3", "type": "task", "name": "承認" },
      { "id": "4", "type": "event", "eventType": "end", "name": "終了（承認済み）" },
      { "id": "9", "type": "task", "name": "どこからも到達しないタスク" },
